APP_NAME="Maximus Trade"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# MySQL config for production (Hostinger):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=maximus_trade
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contato@maximustrade.com.br"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8000,maximustrade.com.br
SANCTUM_TOKEN_PREFIX=mt_
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# SMC Bridge Sync (VPS → Site)
# ---------------------------------------------------------------------------
API_KEY_REQUIRED_SISTEMA_HIBRIDO=
SMC_CLIENT_ID=smc-local
SMC_CLIENT_SECRET=
SMC_BRIDGE_SIGN_REQUESTS=true

# ---------------------------------------------------------------------------
# Scanner → Site Internal Authentication
# ---------------------------------------------------------------------------
SCANNER_INTERNAL_TOKEN=
SCANNER_HMAC_SECRET=
SCANNER_TIMESTAMP_MAX_AGE_SECONDS=300

# ---------------------------------------------------------------------------
# Firebase Cloud Messaging
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=
FCM_ENABLED=false
FCM_DRY_RUN=true

WEBHOOK_RATE_LIMIT=60
WEBHOOK_HOTMART_ENABLED=true
WEBHOOK_HOTMART_SECRET=
WEBHOOK_HOTMART_TOKEN=
WEBHOOK_KIWIFY_ENABLED=true
WEBHOOK_KIWIFY_SECRET=
WEBHOOK_STRIPE_ENABLED=true
WEBHOOK_STRIPE_SECRET=
WEBHOOK_MERCADOPAGO_ENABLED=true
WEBHOOK_MERCADOPAGO_SECRET=
WEBHOOK_PAYPAL_ENABLED=false
WEBHOOK_PAYPAL_SECRET=


FCM_ENABLED=true
FCM_DRY_RUN=false
FIREBASE_PROJECT_ID=maximus-trade-signals
FIREBASE_CREDENTIALS=
